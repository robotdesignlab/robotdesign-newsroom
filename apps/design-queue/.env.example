# RDN S2 — design-queue environment (copy to .env on the OCI host; never commit .env)
# All secrets are injected here — none live in source.

# --- AWS / S3 (read directly by the AWS SDK) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2

# --- GitHub Contents API (fine-grained PAT, contents:write on the repo) ---
GITHUB_PAT=

# --- Overrides (defaults shown; usually leave as-is) ---
# S3_BUCKET=robotdesign-newsroom-2026
# S3_PREFIX=design/img/
# GITHUB_REPO=robotdesignlab/robotdesign-newsroom
# GITHUB_BRANCH=main
# GITHUB_QUEUE_PATH=data/design_queue.json
# PORT=8080
